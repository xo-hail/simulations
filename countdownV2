	print("\r " + str(countdown), end="", flush=True)
	for char in ellipsis:
		print(char, end="", flush=True)
		sleep(0.5)

print("\r                 ", end="") 
print("\r", end="")

for char in game_over:
        print(char, end="", flush=True)
        sleep(0.3)

